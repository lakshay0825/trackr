# PostgreSQL connection URL (SSL usually included for cloud hosts, e.g. Neon / Supabase / Railway)
# Example (Neon): postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Example (local): postgresql://postgres:postgres@localhost:5432/trackr
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

PORT=4000

# Comma-separated origins for CORS (no trailing slashes)
CLIENT_ORIGIN=http://localhost:5173

# Set true on Render (etc.) if you want the in-app “Reset demo” button to re-seed the DB.
# In development, seed-defaults is always allowed without this flag.
ENABLE_PUBLIC_SEED=false

# Optional: enable JWT auth (register/login + per-user applications).
# Generate a long random string for production, e.g. openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
