# MongoDB Atlas (or local): https://www.mongodb.com/docs/atlas/getting-started/
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/trackr?retryWrites=true&w=majority

PORT=4000

# Comma-separated origins for CORS (no trailing slashes)
CLIENT_ORIGIN=http://localhost:5173

# Set true on Render (etc.) if you want the in-app “Reset demo” button to re-seed MongoDB.
# In development, seed-defaults is always allowed without this flag.
ENABLE_PUBLIC_SEED=false
